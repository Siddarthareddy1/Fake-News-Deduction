# Application Environment (development, staging, production)
ENV=development

# Database Configuration
# Local SQLite default for easy setup, override with PostgreSQL in production
DATABASE_URL=sqlite:///./fake_news.db
# Example PostgreSQL URL: postgresql://postgres:password@localhost:5432/fake_news

# Security & JWT Auth Settings
# Generate a secret key using: openssl rand -hex 32
JWT_SECRET_KEY=supersecretjwtkeyforfakenewsverificationgnnproject2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# Redis Caching & Rate Limiting (Optional - falls back to memory if empty)
REDIS_URL=redis://localhost:6379/0

# ML Model Settings
GNN_MODEL_PATH=app/ml_models/weights/gnn_weights.pt
NLP_MODEL_PATH=app/ml_models/weights/bert_classifier
